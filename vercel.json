{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "miss" },
    { "src": "/(.*)", "dest": "/index.html", "check": true }
  ],
  "crons": [
    { "path": "/api/cron/poll", "schedule": "*/1 * * * *" }
  ]
}
